    {
      "name": "⚙️ Scripts — Workflow Actions",
      "item": [
        {
          "name": "1️⃣ Submit Script (Medical Affairs → CONTENT_BRAND_REVIEW)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/scripts/{{scriptId}}/submit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "scripts",
                "{{scriptId}}",
                "submit"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2️⃣ Approve Script (Content/Brand → AGENCY_PRODUCTION)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comments\": \"Script looks good. Sending to Agency for production refinement.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/scripts/{{scriptId}}/approve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "scripts",
                "{{scriptId}}",
                "approve"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2️⃣ Reject Script (Content/Brand → back to DRAFT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comments\": \"Script needs more clarity on the medication section. Please revise.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/scripts/{{scriptId}}/reject",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "scripts",
                "{{scriptId}}",
                "reject"
              ]
            }
          },
          "response": []
        },
        {
          "name": "3️⃣ Submit Revised Script (Agency → MEDICAL_REVIEW)",
          "request": {
            "method": "POST",
            "header": [
